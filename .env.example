# .env.example — Alternative to config.ini via environment variables.
# Copy to .env and source it: `source .env`
# Or export individually before running tracker.py.

export TRACKER_EMAIL="kunj@example.com"
export TRACKER_PHONE="(000) 000-0000"
export TRACKER_LINKEDIN="https://linkedin.com/in/kunjrathod"
export TRACKER_GITHUB="https://github.com/kunjrathod"

# Only needed for `tracker.py remind --send`
export TRACKER_SMTP_HOST="smtp.gmail.com"
export TRACKER_SMTP_PORT="587"
export TRACKER_SMTP_USER="kunj@example.com"
export TRACKER_SMTP_PASS="your_app_password"
export TRACKER_NOTIFY_FROM="kunj@example.com"
export TRACKER_NOTIFY_TO="kunj@example.com"
